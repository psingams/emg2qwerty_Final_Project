  _target_: emg2qwerty.transforms.SpecAugment
  n_time_masks: 1
  time_mask_param: 15
  n_freq_masks: 2
  freq_mask_param: 2
stripchannels:
  _target_: emg2qwerty.transforms.SelectChannels
  n_channels: 16
transforms:
  train:
  - ${to_tensor}
  - ${band_rotation}
  - ${temporal_jitter}
  - ${logspec}
  - ${stripchannels}
  - ${specaug}
  val:
  - _target_: emg2qwerty.transforms.ToTensor
    fields:
    - emg_left
    - emg_right
  - ${logspec}
  - ${stripchannels}
  test: ${transforms.val}
module:
  _target_: emg2qwerty.lightning.CNNLSTMCTCModule
  in_features: 528
  mlp_features:
  - 384
  cnn_channels:
  - 256
  - 256
  cnn_kernel_size: 5
  n_channels: 16
  lstm_hidden_size: 640
  lstm_num_layers: 3
  dropout: 0.2
  bidirectional: true
datamodule:
  _target_: emg2qwerty.lightning.WindowedEMGDataModule
  window_length: 8000
  padding:
  - 1800
  - 200
optimizer:
  _target_: torch.optim.Adam
  lr: 0.001
lr_scheduler:
  scheduler:
    _target_: pl_bolts.optimizers.lr_scheduler.LinearWarmupCosineAnnealingLR
    warmup_epochs: 10
    max_epochs: ${trainer.max_epochs}
    warmup_start_lr: 1.0e-08
    eta_min: 1.0e-06
  interval: epoch
decoder:
  _target_: emg2qwerty.decoder.CTCGreedyDecoder
seed: 1501
batch_size: 32
num_workers: 4
train: true
checkpoint: null
monitor_metric: val/CER
monitor_mode: min
trainer:
  accelerator: gpu
  devices: 1
  num_nodes: 1
  max_epochs: 150
  default_root_dir: ${hydra:runtime.output_dir}
callbacks:
- _target_: pytorch_lightning.callbacks.LearningRateMonitor
